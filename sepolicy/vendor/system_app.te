# FM radio needs to set fm properties
set_prop(system_app, fm_prop)

# zram
r_dir_file(system_app sysfs_zram)

allow system_app camera_prop:property_service set;
get_prop(system_app, camera_prop);

allow system_app spectrum_prop:property_service set;
get_prop(system_app, spectrum_prop);
allow system_app spectrum_prop:file read;
allow system_app sysfs_kcal:dir search;
allow system_app sysfs_fastcharge:file { open read getattr write };
allow system_app sysfs_kcal:file rw_file_perms;
allow system_app sysfs_kcal:file { getattr open write };
allow system_app sysfs_vibrator:dir search;
allow system_app sysfs_vibrator:file { getattr open read write };
